# Evalora Backend Configuration
# Copy this file to .env and fill in your values

# Application
DEBUG=true

# CORS - Frontend URLs allowed
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Database - Neon PostgreSQL
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LiveKit Configuration
# Get these from https://livekit.io or your self-hosted LiveKit server
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud

# OpenAI Configuration (for voice conversation with ChatGPT)
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ElevenLabs Configuration (optional - for custom voices)
# Get this from https://elevenlabs.io
ELEVENLABS_API_KEY=

# Tavus Configuration
# Get this from https://tavus.io
TAVUS_API_KEY=
TAVUS_BASE_URL=https://api.tavus.io/v2

# Tavus Network Configuration (optional)
# Configure proxy if your network requires it to access api.tavus.io
# TAVUS_HTTP_PROXY=http://proxy.example.com:8080
# TAVUS_HTTPS_PROXY=http://proxy.example.com:8080

# Tavus Timeout Configuration (optional, defaults shown)
# TAVUS_CONNECT_TIMEOUT=10.0  # Connection timeout in seconds
# TAVUS_READ_TIMEOUT=30.0     # Read timeout in seconds

# Tavus Retry Configuration (optional, defaults shown)
# TAVUS_MAX_RETRIES=3         # Maximum number of retry attempts for network errors
# TAVUS_RETRY_BACKOFF=1.5     # Exponential backoff factor (wait_time = base_delay * (backoff_factor ^ attempt))
