# Evalora Backend Configuration
# Copy this file to .env and fill in your values

# Application
DEBUG=true

# CORS - Frontend URLs allowed
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# LiveKit Configuration
# Get these from https://livekit.io or your self-hosted LiveKit server
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud

# Tavus Configuration
# Get this from https://tavus.io
TAVUS_API_KEY=
TAVUS_BASE_URL=https://api.tavus.io/v2
