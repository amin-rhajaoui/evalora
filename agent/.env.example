# LiveKit Agent Configuration
# Copy this file to .env and fill in your values

# LiveKit Cloud credentials (same as backend)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud

# OpenAI API Key (for GPT and TTS)
OPENAI_API_KEY=sk-...

# ElevenLabs API Key (optional - for custom voices)
ELEVENLABS_API_KEY=

# Override voix par avatar (optionnel; sinon utilisées depuis le backend)
# ELEVENLABS_VOICE_CLEA=
# ELEVENLABS_VOICE_ALEX=
# ELEVENLABS_VOICE_KARIM=
# ELEVENLABS_VOICE_CLAIRE=
# ELEVENLABS_VOICE_ID=  # fallback global

# Backend API URL (for session, avatar, transition, transcriptions)
BACKEND_URL=http://localhost:8000
